    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
